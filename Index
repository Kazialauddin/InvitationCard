
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wedding Invitation</title>

<style>
body {
  margin: 0;
  font-family: 'Georgia', serif;
  background: linear-gradient(to bottom, #f8f5f0, #fff);
  text-align: center;
  color: #333;
}

.container {
  padding: 30px;
}

.card {
  background: white;
  border-radius: 12px;
  padding: 30px;
  max-width: 400px;
  margin: auto;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  animation: fadeIn 1.5s ease;
}

h1 {
  font-size: 28px;
  margin-bottom: 10px;
}

.names {
  font-size: 24px;
  margin: 20px 0;
  color: #b48a3c;
}

.guest {
  font-size: 18px;
  margin-bottom: 20px;
}

.details {
  font-size: 16px;
  line-height: 1.6;
}

button {
  margin-top: 20px;
  padding: 10px 20px;
  border: none;
  background: #b48a3c;
  color: white;
  border-radius: 6px;
  cursor: pointer;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px);}
  to { opacity: 1; transform: translateY(0);}
}
</style>
</head>

<body>

<div class="container">
  <div class="card">
    
    <h1>Wedding Invitation</h1>
    
    <div class="guest" id="guestName">
      Dear Guest
    </div>

    <div class="names">
      Rahim ❤️ Karima
    </div>

    <div class="details">
      You are cordially invited to celebrate our wedding.<br><br>
      📅 Date: 25 December 2026 <br>
      ⏰ Time: 7:00 PM <br>
      📍 Venue: Dhaka Convention Hall
    </div>

    <button onclick="alert('Thank you for your response!')">
      RSVP
    </button>

  </div>
</div>

<script>
// Get guest name from URL
const params = new URLSearchParams(window.location.search);
const name = params.get("name");

if(name){
  document.getElementById("guestName").innerText = "Dear " + name;
}
</script>

</body>
</html>
